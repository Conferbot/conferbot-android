    android:orientation="horizontal"
    android:padding="12dp">

    <View
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_typing_dot" />

    <View
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_typing_dot" />

    <View
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_typing_dot" />

</LinearLayout>
